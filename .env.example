# Monorepo Environment Template
# Copy relevant values into:
# - server/.env (backend)
# - Medicus/.env (frontend)

# ==============================
# Backend (server/.env)
# ==============================

# MongoDB Atlas connection URI
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.qoqz27g.mongodb.net/medicus?retryWrites=true&w=majority&appName=Cluster0

# Optional local fallback for development
MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/medicus

# JWT signing key (change in production)
JWT_SECRET=replace_with_strong_random_secret

# API server port
PORT=5001

# Environment mode
NODE_ENV=development

# Comma-separated allowed origins for CORS
# Example: https://your-frontend.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ==============================
# Frontend (Medicus/.env)
# ==============================

# Google Maps API key
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Production API URL (set for Vercel frontend deployment)
# Example: https://your-backend.vercel.app/api
# Keep empty locally so frontend can use /api proxy
REACT_APP_API_URL=
